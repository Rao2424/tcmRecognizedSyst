.profile-page {
  padding-bottom: 188rpx;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-note {
  color: #8a8378;
  font-size: 22rpx;
}

.hero-card {
  position: relative;
  padding: 32rpx;
  overflow: hidden;
}

.hero-card::after {
  content: "";
  position: absolute;
  top: -120rpx;
  right: -90rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(198, 142, 72, 0.18) 0%, rgba(198, 142, 72, 0) 72%);
}

.hero-card__top {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.avatar-badge {
  flex-shrink: 0;
  width: 108rpx;
  height: 108rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #22473f 0%, #37695d 100%);
  box-shadow: 0 16rpx 36rpx rgba(34, 71, 63, 0.2);
  color: #fff8ec;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 108rpx;
  text-align: center;
}

.hero-card__content {
  position: relative;
  z-index: 1;
  flex: 1;
}

.hero-kicker {
  display: inline-flex;
  margin-bottom: 14rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(34, 71, 63, 0.1);
  color: #22473f;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.stats-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}

.stat-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.92);
  border: 1rpx solid rgba(34, 71, 63, 0.06);
}

.stat-card__label {
  color: #7d766b;
  font-size: 22rpx;
}

.stat-card__value {
  margin-top: 12rpx;
  color: #17342d;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 46rpx;
  font-weight: 700;
}

.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.shortcut-card {
  min-height: 208rpx;
  padding: 24rpx;
}

.shortcut-card--forest {
  background: linear-gradient(180deg, rgba(241, 248, 244, 0.98) 0%, rgba(228, 240, 235, 0.95) 100%);
}

.shortcut-card--amber {
  background: linear-gradient(180deg, rgba(250, 246, 236, 0.98) 0%, rgba(247, 236, 214, 0.95) 100%);
}

.shortcut-card--mist {
  background: linear-gradient(180deg, rgba(239, 245, 246, 0.98) 0%, rgba(229, 238, 241, 0.95) 100%);
}

.shortcut-card--clay {
  background: linear-gradient(180deg, rgba(250, 242, 238, 0.98) 0%, rgba(246, 232, 224, 0.95) 100%);
}

.shortcut-card__badge {
  display: inline-flex;
  margin-bottom: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #6b6459;
  font-size: 20rpx;
}

.shortcut-card__title {
  color: #17342d;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 32rpx;
  font-weight: 700;
}

.shortcut-card__desc {
  margin-top: 18rpx;
  color: #6d6a60;
  font-size: 24rpx;
  line-height: 1.7;
}

.shortcut-card__arrow {
  margin-top: 22rpx;
  color: #22473f;
  font-size: 22rpx;
  font-weight: 600;
}

.utility-panel,
.project-panel {
  padding: 28rpx;
}

.service-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(34, 71, 63, 0.08);
}

.service-row--first {
  padding-top: 8rpx;
  border-top: none;
}

.service-row__main {
  flex: 1;
}

.service-row__title {
  color: #17342d;
  font-size: 30rpx;
  font-weight: 600;
}

.service-row__desc {
  margin-top: 10rpx;
  color: #787264;
  font-size: 24rpx;
  line-height: 1.7;
}

.service-row__side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.service-row__meta {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f1e7d3;
  color: #6d634d;
  font-size: 20rpx;
}

.service-row__arrow {
  color: #a19686;
  font-size: 26rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 6rpx;
}

.status-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(34, 71, 63, 0.08);
  color: #2b5248;
  font-size: 22rpx;
}

.info-block {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 252, 247, 0.95);
  border: 1rpx solid rgba(34, 71, 63, 0.08);
}

.info-block__label {
  color: #7f786d;
  font-size: 22rpx;
}

.info-block__value {
  margin-top: 14rpx;
  color: #17342d;
  font-size: 26rpx;
  line-height: 1.7;
  word-break: break-all;
}

.summary-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(244, 240, 231, 0.95) 0%, rgba(240, 233, 219, 0.95) 100%);
}

.summary-card__title {
  color: #17342d;
  font-size: 28rpx;
  font-weight: 600;
}

.summary-card__desc {
  margin-top: 12rpx;
  color: #756f63;
  font-size: 24rpx;
  line-height: 1.8;
}
