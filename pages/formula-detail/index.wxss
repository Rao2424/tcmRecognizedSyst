.detail-hero,
.detail-card {
  margin-top: 24rpx;
  padding: 30rpx;
}

.detail-label {
  display: inline-flex;
  margin-bottom: 16rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(198, 142, 72, 0.12);
  color: #8b5a21;
  font-size: 22rpx;
}

.detail-line {
  margin-top: 18rpx;
  color: #6d675c;
  font-size: 27rpx;
  line-height: 1.8;
}

.herb-pill {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 22rpx;
  background: #f2ead9;
  color: #365249;
  font-size: 25rpx;
}
