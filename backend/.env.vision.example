# 本地视觉适配服务配置示例
# 该服务通过 OpenAI 兼容协议调用外部视觉模型，可接 OpenAI、阿里百炼、智谱等供应商

VISION_ADAPTER_NAME=TCM Vision Adapter
VISION_PROVIDER_NAME=DashScope

# 适配服务自身的鉴权口令，可选
# 如果配置了该值，请在主后端的 VISION_API_KEY 中填入同一个值
ADAPTER_API_KEY=

# OpenAI 兼容接口配置
# 阿里百炼示例: https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱示例: https://open.bigmodel.cn/api/paas/v4
# OpenAI 示例: https://api.openai.com/v1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# 请填写当前供应商可用的视觉模型名称
# 例如阿里百炼可用 qwen-vl-plus-latest / qwen-vl-max-latest
# 例如智谱可用 glm-4.6v
# 例如 OpenAI 可用 gpt-4.1-mini
VISION_MODEL=

VISION_REQUEST_TIMEOUT=60
VISION_TEMPERATURE=0.1
VISION_IMAGE_DETAIL=high
VISION_MAX_CANDIDATES=3
VISION_JSON_MODE=true
