PROJECT_NAME=TCM Visual Query System API
PROJECT_VERSION=0.1.0
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=tcm
SQL_ECHO=false
# 建议指向本地视觉适配服务，例如 http://127.0.0.1:8001/recognize
# 留空时仅按文件名执行降级识别
VISION_API_URL=
# 如果本地视觉适配服务配置了 ADAPTER_API_KEY，则这里填同一个值
VISION_API_KEY=
VISION_API_TIMEOUT=20
