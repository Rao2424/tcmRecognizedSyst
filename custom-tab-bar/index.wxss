.tabbar-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 0 24rpx 30rpx;
  background: linear-gradient(180deg, rgba(239, 230, 216, 0) 0%, rgba(239, 230, 216, 0.95) 48%);
  z-index: 999;
}

.tabbar-inner {
  display: flex;
  justify-content: space-between;
  padding: 16rpx;
  border: 2rpx solid rgba(34, 71, 63, 0.08);
  border-radius: 36rpx;
  background: rgba(255, 249, 240, 0.95);
  box-shadow: 0 20rpx 60rpx rgba(53, 44, 31, 0.12);
}

.tabbar-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0 10rpx;
  color: #807a6d;
}

.tabbar-item--active {
  color: #22473f;
}

.tabbar-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #efe7d5;
  color: inherit;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 56rpx;
  text-align: center;
}

.tabbar-item--active .tabbar-icon {
  background: linear-gradient(135deg, #22473f 0%, #37695f 100%);
  color: #fff8ec;
}

.tabbar-text {
  font-size: 22rpx;
}

.tabbar-marker {
  position: absolute;
  bottom: 0;
  width: 36rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #c68e48;
}
